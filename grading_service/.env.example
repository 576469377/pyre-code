# Path to SQLite database file. Default: ../data/pyre.db (relative to project root)
# DB_PATH=/app/data/pyre.db

# Per-test execution timeout in seconds. Default: 30
# Note: only enforced when running on the main thread (e.g. tests). FastAPI sync
# endpoints run in a thread pool, so this is best-effort in production.
# EXEC_TIMEOUT_SEC=30

# Max /grade and /run requests per IP per minute. Default: 30
# GRADE_RATE_MAX=30

# Comma-separated list of allowed CORS origins. Default: *
# Example: CORS_ORIGINS=https://pyre.example.com,http://localhost:3000
# CORS_ORIGINS=*

# Logging level: DEBUG, INFO, WARNING, ERROR. Default: INFO
# LOG_LEVEL=INFO
